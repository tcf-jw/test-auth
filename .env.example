# Copy to .env and fill in. These are NOT secrets (public SPA client),
# but they are environment-specific so they live outside the source.
VITE_CLIENT_ID=
VITE_TENANT_ID=

# Required: SharePoint sharing URL of the parquet/xlsx file to display.
# No URL is committed to source — it must be provided here (or as a repo
# variable in CI). Format is auto-detected (parquet or xlsx).
VITE_SHARE_URL=

# Optional override:
# Defaults to window.location.origin + base ("/test-auth/").
# Only set this if you need a different redirect URI than the site root.
# VITE_REDIRECT_URI=
