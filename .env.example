# Copy to .env and fill in. These are NOT secrets (public SPA client),
# but they are environment-specific so they live outside the source.
VITE_CLIENT_ID=
VITE_TENANT_ID=

# Optional overrides:
# Defaults to the TopCutAnalytics sharing URL baked into src/config.ts
# VITE_SHARE_URL=
# Defaults to window.location.origin + base ("/test-auth/").
# Only set this if you need a different redirect URI than the site root.
# VITE_REDIRECT_URI=
